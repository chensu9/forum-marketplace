// 1. НАСТРОЙКИ PRISMA
generator client {
  provider        = "prisma-client-js"
  // Эта настройка нужна для работы с адаптером PostgreSQL в Prisma 7+
  previewFeatures = ["driverAdapters"] 
}

datasource db {
  provider = "postgresql"
  // Обрати внимание: url здесь НЕТ, так как мы настроили prisma.config.ts!
}

// ==========================================
// 2. ENUMS (Перечисления статусов и ролей)
// ==========================================

enum Role {
  USER
  VIP
  MODERATOR
  ADMIN
  BANNED
}

enum OrderStatus {
  PENDING       // Ожидает подтверждения
  IN_PROGRESS   // В работе
  COMPLETED     // Завершён
  CANCELLED     // Отменён
}

// ==========================================
// 3. ПОЛЬЗОВАТЕЛИ
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String    @unique
  email         String    @unique
  password      String?
  image         String?
  bio           String?   // Описание профиля
  reputation    Int       @default(0) // Репутация (лайки + посты)
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // --- СВЯЗИ (Relations) ---
  // Форум
  posts         Post[]    @relation("UserPosts")
  comments      Comment[] @relation("UserComments")
  likedPosts    Post[]    @relation("PostLikes") // Посты, которые лайкнул юзер

  // Маркетплейс
  listings      Listing[] @relation("UserListings")
  ordersBought  Order[]   @relation("BuyerOrders")
  ordersSold    Order[]   @relation("SellerOrders")
}

// ==========================================
// 4. ФОРУМ (Посты, Теги, Комментарии)
// ==========================================

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  views     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Автор поста
  authorId  String
  author    User     @relation("UserPosts", fields: [authorId], references: [id], onDelete: Cascade)

  // Теги, комментарии и лайки
  tags      Tag[]
  comments  Comment[]
  likedBy   User[]   @relation("PostLikes")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[]
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Автор комментария
  authorId  String
  author    User     @relation("UserComments", fields: [authorId], references: [id], onDelete: Cascade)

  // Пост, к которому относится комментарий
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)

  // Вложенные комментарии (Ответы на комментарии)
  parentId  String?
  parent    Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[] @relation("CommentReplies")
}

// ==========================================
// 5. МАРКЕТПЛЕЙС (Объявления и Заказы)
// ==========================================

model Listing {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  price       Float    // Цена услуги/товара
  images      String[] // Ссылки на картинки
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Продавец
  sellerId    String
  seller      User     @relation("UserListings", fields: [sellerId], references: [id], onDelete: Cascade)

  // Заказы по этому объявлению
  orders      Order[]
}

model Order {
  id        String      @id @default(cuid())
  price     Float       // Фиксируем цену на момент заказа (если продавец её изменит)
  status    OrderStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Товар/Услуга
  listingId String
  listing   Listing     @relation(fields: [listingId], references: [id])

  // Покупатель
  buyerId   String
  buyer     User        @relation("BuyerOrders", fields: [buyerId], references: [id])

  // Продавец
  sellerId  String
  seller    User        @relation("SellerOrders", fields: [sellerId], references: [id])
}